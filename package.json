{
  "name": "lab_1",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": "24.14.0"
  },
  "imports": {
    "#configs/*": "./configs/*",
    "#constants/*": "./constants/*",
    "#controllers/*": "./controllers/*",
    "#routes/*": "./routes/*",
    "#data/*": "./data/*",
    "#schemas/*": "./schemas/*",
    "#state/*": "./state/*",
    "#utils/*": "./utils/*",
    "#validators/*": "./validators/*"
  },
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "node --env-file=.env --watch server.js",
    "lint": "eslint -c ./configs/eslint/eslint.config.js .",
    "lint:fix": "eslint -c ./configs/eslint/eslint.config.js --fix .",
    "format": "prettier -c ./configs/prettier/.prettierrc . --write",
    "format:check": "prettier -c ./configs/prettier/.prettierrc . . --check",
    "check": "npm run lint && npm run format:check",
    "predev": "npm run check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/sensible": "^6.0.4",
    "fastify": "^5.8.2"
  }
}
