{
	"name": "lab_1",
	"version": "1.0.0",
	"description": "",
	"license": "ISC",
	"author": "",
	"type": "module",
	"main": "app.js",
	"engines": {
		"node": "24.14.0"
	},
	"imports": {
		"#configs/*": "./configs/*",
		"#data/*": "./data/*",
		"#methods/*": "./methods/*",
		"#schemas/*": "./schemas/*",
		"#utils/*": "./utils/*",
		"#validators/*": "./validators/*"
	},
	"scripts": {
		"start": "node --env-file=.env app.js",
		"dev": "node --env-file=.env --watch app.js",
		"lint": "eslint -c ./configs/eslint/eslint.config.js .",
		"lint:fix": "eslint -c ./configs/eslint/eslint.config.js --fix .",
		"format": "prettier -c ./configs/prettier/.prettierrc . --write",
		"format:check": "prettier -c ./configs/prettier/.prettierrc . . --check",
		"check": "npm run lint && npm run format:check",
		"predev": "npm run check"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.4.0",
		"prettier": "3.8.1"
	},
	"dependencies": {
		"ajv": "^8.18.0"
	}
}
