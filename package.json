{
  "name": "lab_1",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": "24.14.0"
  },
  "imports": {
    "#configs/*": "./configs/*",
    "#constants/*": "./constants/*",
    "#controllers/*": "./controllers/*",
    "#data/*": "./data/*",
    "#repositories/*": "./repositories/*",
    "#routes/*": "./routes/*",
    "#schemas/*": "./schemas/*",
    "#src/*": "./src/*",
    "#state/*": "./state/*",
    "#utils/*": "./utils/*"
  },
  "scripts": {
    "start": "node --env-file=.env server.js",
    "dev": "node --env-file=.env --watch server.js",
    "external": "json-server db.json --port 3001",
    "seed": "node src/scripts/seed.js",
    "migrate": "node src/migrations/migrate.js",
    "lint": "eslint -c ./configs/eslint/eslint.config.js .",
    "lint:fix": "eslint -c ./configs/eslint/eslint.config.js --fix .",
    "format": "prettier -c ./configs/prettier/.prettierrc . --write",
    "format:check": "prettier -c ./configs/prettier/.prettierrc . . --check",
    "check": "npm run lint && npm run format:check",
    "predev": "npm run check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "json-server": "^0.17.4",
    "pino-pretty": "^13.1.3",
    "prettier": "3.8.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.1.1",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "fastify": "^5.8.2"
  }
}
